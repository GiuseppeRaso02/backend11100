# === Server ===
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# === MongoDB ===
# Crea un cluster gratis su https://www.mongodb.com/cloud/atlas
# Poi prendi la connection string e mettila qui
MONGO_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/undrgrd?retryWrites=true&w=majority

# === JWT ===
# Genera un secret robusto: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-questo-con-una-stringa-lunga-random-almeno-64-caratteri
JWT_EXPIRES_IN=7d

# === Bootstrap admin (usato da `npm run seed:admin`) ===
ADMIN_EMAIL=admin@undrgrd.com
ADMIN_PASSWORD=ChangeMe123!

# === Cloudinary ===
# Crea account gratis su https://cloudinary.com → Dashboard → Account Details
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
